# Tastytrade API credentials
# Get these from: https://my.tastytrade.com/app.html#/manage/api-access/oauth-applications
TASTYTRADE_CLIENT_SECRET=your_client_secret_here
TASTYTRADE_REFRESH_TOKEN=your_refresh_token_here

# Optional market/news fallback providers for the web revamp
MASSIVE_API_KEY=your_massive_api_key_here
BENZINGA_API_KEY=your_benzinga_api_key_here

# Recommendations use the local Codex CLI with ChatGPT subscription OAuth.
# Do not set Anthropic or other LLM API keys for Position Pilot recommendations.
# Install and sign in to the Codex CLI separately (ChatGPT sign-in flow).
